#include <iostream>
#include <vector>
#include <iomanip>
using namespace std;

class Course {
private:
    string grade;
    int creditHours;

public:
    Course(string g, int ch) {
        grade = g;
        creditHours = ch;
    }

    double getGradePoint() {
        if (grade == "A+" || grade == "A")
            return 4.0;
        else if (grade == "A-")
            return 3.7;
        else if (grade == "B+")
            return 3.3;
        else if (grade == "B")
            return 3.0;
        else if (grade == "B-")
            return 2.7;
        else if (grade == "C+")
            return 2.3;
        else if (grade == "C")
            return 2.0;
        else if (grade == "C-")
            return 1.7;
        else if (grade == "D+")
            return 1.3;
        else if (grade == "D")
            return 1.0;
        else
            return 0.0;
    }

    double getQualityPoints() {
        return getGradePoint() * creditHours;
    }

    int getCredits() {
        return creditHours;
    }

    string getGrade() {
        return grade;
    }
};

class Student {
private:
    vector<Course> courses;

public:
    void inputCourses() {
        int n;

        cout << "Enter number of courses: ";
        cin >> n;

        for (int i = 0; i < n; i++) {
            string grade;
            int credits;

            cout << "\nCourse " << i + 1 << endl;

            cout << "Enter Grade: ";
            cin >> grade;

            cout << "Enter Credit Hours: ";
            cin >> credits;

            courses.push_back(Course(grade, credits));
        }
    }

    double calculateCGPA() {
        double totalGradePoints = 0;
        int totalCredits = 0;

        for (int i = 0; i < courses.size(); i++) {
            totalGradePoints += courses[i].getQualityPoints();
            totalCredits += courses[i].getCredits();
        }

        if (totalCredits == 0)
            return 0;

        return totalGradePoints / totalCredits;
    }

    void displayResult() {
        cout << "\n----- Course Details -----\n";

        for (int i = 0; i < courses.size(); i++) {
            cout << "Course " << i + 1
                << " | Grade: " << courses[i].getGrade()
                << " | Credit Hours: " << courses[i].getCredits()
                << endl;
        }

        cout << fixed << setprecision(2);
        cout << "\nFinal CGPA: " << calculateCGPA() << endl;
    }
};

int main() {
    Student s;

    s.inputCourses();
    s.displayResult();

    return 0;
}
