#include <iostream>
#include <fstream>
#include <string>

using namespace std;

class User
{
private:
    string username;
    string password;

public:
    void registerUser();
    void loginUser();
    bool usernameExists(string);
};

bool User::usernameExists(string name)
{
    ifstream file("users.txt");

    string user, pass;

    while (file >> user >> pass)
    {
        if (user == name)
        {
            file.close();
            return true;
        }
    }

    file.close();
    return false;
}

void User::registerUser()
{
    cout << "\nEnter Username: ";
    cin >> username;

    if (usernameExists(username))
    {
        cout << "Username already exists.\n";
        return;
    }

    cout << "Enter Password: ";
    cin >> password;

    if (username.length() < 3 || password.length() < 5)
    {
        cout << "Invalid username or password.\n";
        return;
    }

    ofstream file("users.txt", ios::app);

    file << username << " " << password << endl;

    file.close();

    cout << "Registration Successful.\n";
}

void User::loginUser()
{
    cout << "\nEnter Username: ";
    cin >> username;

    cout << "Enter Password: ";
    cin >> password;

    ifstream file("users.txt");

    string user, pass;
    bool found = false;

    while (file >> user >> pass)
    {
        if (user == username && pass == password)
        {
            found = true;
            break;
        }
    }

    file.close();

    if (found)
        cout << "Login Successful.\n";
    else
        cout << "Invalid Username or Password.\n";
}

int main()
{
    User user;

    int choice;

    do
    {
        cout << "\n===== Login & Registration System =====\n";
        cout << "1. Register\n";
        cout << "2. Login\n";
        cout << "3. Exit\n";
        cout << "Enter Choice: ";
        cin >> choice;

        switch (choice)
        {
        case 1:
            user.registerUser();
            break;

        case 2:
            user.loginUser();
            break;

        case 3:
            cout << "Program Ended.\n";
            break;

        default:
            cout << "Invalid Choice.\n";
        }

    } while (choice != 3);

    return 0;
}
